{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/session_start.py"
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "matcher": "^(edit|create)$",
        "command": "python .github/hooks/scripts/secret_scan.py"
      },
      {
        "type": "command",
        "matcher": "^(bash|powershell)$",
        "command": "python .github/hooks/scripts/guard_bash.py"
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "matcher": "^(edit|create)$",
        "command": "python .github/hooks/scripts/post_edit_format.py"
      },
      {
        "type": "command",
        "matcher": "^(edit|create)$",
        "command": "python .github/hooks/scripts/doc_link_check.py"
      },
      {
        "type": "command",
        "matcher": "github-mcp-server",
        "command": "python .github/hooks/scripts/github_audit.py"
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/run_tests.py"
      },
      {
        "type": "command",
        "command": "python .github/hooks/scripts/doc_link_check.py"
      }
    ]
  }
}
